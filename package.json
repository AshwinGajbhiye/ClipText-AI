{
  "name": "caption-generator-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "db:generate": "turbo run generate --filter=@repo/database",
    "db:push": "dotenv -e .env -- prisma db push --schema=packages/database/prisma/schema.prisma"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "turbo": "^2.0.0"
  }
}
