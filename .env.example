# Database & Redis
POSTGRES_USER=postgres
POSTGRES_PASSWORD=supersecret
POSTGRES_DB=caption_generator
DATABASE_URL="postgresql://postgres:supersecret@postgres:5432/caption_generator?schema=public"
REDIS_URL="redis://redis:6379"

# Cloudflare R2 / Local MinIO
# For local testing, use the MinIO container settings:
CLOUDFLARE_R2_ENDPOINT="http://localhost:9000"
R2_ACCESS_KEY_ID="minioadmin"
R2_SECRET_ACCESS_KEY="minioadmin123"
R2_BUCKET_NAME="caption-bucket"

# Clerk Auth
CLERK_SECRET_KEY="sk_live_..."
CLERK_PUBLISHABLE_KEY="pk_live_..."

# Frontend
FRONTEND_URL="http://localhost:5173"
